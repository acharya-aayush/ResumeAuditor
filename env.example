GEMINI_API_KEY=

# Vercel KV (optional, recommended for production-grade rate limits)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Comma-separated list of trusted frontend origins
# Example: http://localhost:3000,https://resume-auditor.example.com
ALLOWED_ORIGINS=

# Optional hard allow-list for Gemini models
# Example: gemini-2.5-flash,gemini-2.0-flash
ALLOWED_GEMINI_MODELS=

# Optional request controls
DAILY_LIMIT=10
